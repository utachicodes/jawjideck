{
  "name": "@ardudeck/ardudeck-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ardudeck-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ardudeck/companion-types": "workspace:*",
    "ws": "^8.17.0",
    "express": "^4.21.0",
    "bonjour-service": "^1.3.0",
    "systeminformation": "^5.25.0",
    "node-pty": "^1.0.0",
    "dockerode": "^4.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "@types/express": "^4.17.0",
    "@types/dockerode": "^3.3.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  }
}
