{
  "name": "@ardudeck/module-sdk",
  "version": "0.1.0",
  "description": "SDK for building ArduDeck modules",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./esbuild": "./src/esbuild.ts"
  },
  "scripts": {
